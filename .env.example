# Copy this file to .env and fill in your real values. Never commit .env.

# Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Port for the tiny health-check HTTP server (Railway sets this automatically;
# only matters if you deploy on Render or ping it with UptimeRobot)
PORT=3000

# Seconds between polling cycles. Default 30 is already fast for this use case -
# see README before lowering it much further.
POLL_INTERVAL_SECONDS=30
