# Copy this file to .env and fill in your real values. Never commit .env.

# Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Port for the tiny health-check HTTP server (Railway sets this automatically;
# only matters if you deploy on Render or ping it with UptimeRobot)
PORT=3000

# Seconds between polling cycles. Default 30 is already fast for this use case. A built-in
# per-channel backoff (see src/poller.js) automatically pauses any channel that starts
# erroring repeatedly, so a dead/blocked channel doesn't get hammered.
POLL_INTERVAL_SECONDS=30
